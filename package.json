{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "bun@1.3.6",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/run-dev.mjs",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:web:turbopack": "bun run --cwd apps/web dev:turbopack",
    "dev:web:webpack": "bun run --cwd apps/web dev:webpack",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:desktop": "bun run --cwd apps/desktop dev",
    "build": "turbo build --filter=!@workspace/desktop",
    "build:desktop": "bun run --cwd apps/desktop build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "bun run --cwd packages/db prisma:generate",
    "db:push": "bun run --cwd packages/db prisma:push",
    "db:migrate": "bun run --cwd packages/db prisma:migrate",
    "db:seed": "bun run --cwd packages/db prisma:seed"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "prettier": "^3.8.1",
    "turbo": "^2.5.8",
    "typescript": "~5.9.2"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.59.0",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.1.14",
    "lightningcss-win32-x64-msvc": "^1.31.1"
  }
}
