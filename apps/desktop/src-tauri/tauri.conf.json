{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lynx",
  "version": "0.1.0",
  "identifier": "com.lynx.local",
  "build": {
    "beforeDevCommand": "bun run --cwd ../web dev",
    "devUrl": "http://127.0.0.1:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lynx",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
